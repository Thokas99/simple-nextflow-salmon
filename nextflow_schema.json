{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Thokas99/simple-nextflow-salmon/nextflow_schema.json",
  "title": "simple-nextflow-salmon parameters",
  "type": "object",
  "properties": {
    "samplesheet": {"type": ["string", "null"], "description": "CSV/TSV samplesheet with sample, fastq_1, fastq_2"},
    "fastq_dir": {"type": ["string", "null"], "description": "Directory scanned recursively to generate a samplesheet"},
    "outdir": {"type": "string", "default": "results"},
    "reference_dir": {"type": "string", "default": "${projectDir}/reference/GRCh38_GENCODE/raw", "description": "Raw GENCODE reference directory; defaults to the pipeline checkout"},
    "gencode_release": {"type": "integer", "minimum": 1, "default": 50},
    "genome_patch": {"type": "integer", "minimum": 1, "default": 14},
    "lib_type": {"type": "string", "default": "A"},
    "salmon_k": {"type": "integer", "minimum": 19, "maximum": 31, "default": 31},
    "validate_only": {"type": "boolean", "default": false},
    "rebuild_reference": {"type": "boolean", "default": false}
  }
}
